{
  "name": "@drawio/mcp-app",
  "version": "1.0.2",
  "description": "Draw.io MCP App server - renders interactive diagrams inline in AI chat interfaces",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "drawio-mcp-app": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "build:worker": "node src/build-html.js",
    "dev:worker": "npm run build:worker && wrangler dev",
    "deploy": "npm run build:worker && wrangler deploy"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/ext-apps": "^1.1.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^4",
    "@xmldom/xmldom": "^0.9.8",
    "pako": "^2.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "wrangler": "^4"
  }
}
